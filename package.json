{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@AI-Trash/opencode-models-discovery",
  "version": "0.12.0",
  "description": "OpenCode plugin for auto-discovery of OpenAI-compatible models with dynamic provider configuration",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "types": "./dist/esm/index.d.ts",
  "module": "./dist/esm/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "rslib build && npm run typecheck && npm run test:run",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "validate": "npm run lint && npm run typecheck && npm run test:run",
    "validate:config": "bun scripts/validate-config.ts",
    "release": "bun scripts/release.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "openai-compatible",
    "model-discovery",
    "plugin",
    "local-llm",
    "ollama",
    "lmstudio",
    "lm-studio",
    "localai"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "opencode": ">=1.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AI-Trash/opencode-models-discovery.git"
  },
  "dependencies": {
    "xdg-basedir": "^5.1.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.4.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.10",
    "@rslib/core": "^0.23.1",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
